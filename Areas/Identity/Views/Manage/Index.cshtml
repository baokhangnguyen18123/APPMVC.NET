@model IndexViewModel
@{
    ViewData["Title"] = "Quản lý tài khoản của bạn";
}

<div class="container mt-4 mb-5">
    <h2 class="text-primary border-bottom pb-2 mb-4">@ViewData["Title"]</h2>

    @if (!string.IsNullOrEmpty(ViewData["StatusMessage"]?.ToString()))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @ViewData["StatusMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h4 class="mb-0 text-secondary">Cập nhật thông tin tài khoản</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">

                <dt class="col-md-4 fs-5 text-dark mt-2">Thông tin cơ bản:</dt>
                <dd class="col-md-8">
                    <div class="bg-light p-3 rounded border mb-3">
                        <dl class="row mb-0">
                            <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => Model.profile.UserName)</dt>
                            <dd class="col-sm-7 fw-bold">@Html.DisplayFor(m => Model.profile.UserName)</dd>

                            <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => Model.profile.UserEmail)</dt>
                            <dd class="col-sm-7 fw-bold">@Html.DisplayFor(m => Model.profile.UserEmail)</dd>

                            <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => Model.profile.PhoneNumber)</dt>
                            <dd class="col-sm-7">@(Model.profile.PhoneNumber ?? "Chưa cập nhật")</dd>

                            <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => Model.profile.HomeAdress)</dt>
                            <dd class="col-sm-7">@(Model.profile.HomeAdress ?? "Chưa cập nhật")</dd>

                            <dt class="col-sm-5 text-muted mb-0">@Html.DisplayNameFor(m => Model.profile.BirthDate)</dt>
                            <dd class="col-sm-7 mb-0">
                                @(Model.profile.BirthDate?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")
                            </dd>
                        </dl>
                    </div>
                    <a asp-action="EditProfile" class="btn btn-outline-primary btn-sm mb-4"><i
                        class="bi bi-pencil-square"></i> Chỉnh sửa thông tin</a>
                    </dd>

                    <hr class="text-muted" />

                    <dt class="col-md-4 fs-5 text-dark mt-2">Mật khẩu:</dt>
                    <dd class="col-md-8 d-flex align-items-center mt-2 mb-4">
                        @if (Model.HasPassword)
                        {
                            <span class="badge bg-success me-3">Đã thiết lập</span>
                            <a asp-controller="Manage" asp-action="ChangePassword" class="btn btn-secondary btn-sm">Đổi mật
                                khẩu</a>
                            }
                    else
                            {
                                <span class="badge bg-warning text-dark me-3">Chưa có mật khẩu</span>
                                <a asp-controller="Manage" asp-action="SetPassword" class="btn btn-primary btn-sm">Tạo mật khẩu</a>
                            }
                        </dd>

                        <hr class="text-muted" />

                        <dt class="col-md-4 fs-5 text-dark mt-2">Liên kết ngoài (OAuth):</dt>
                        <dd class="col-md-8 mt-2 mb-4">
                            <span class="fw-semibold">Có @Model.Logins.Count liên kết.</span>
                            <a asp-controller="Manage" asp-action="ManageLogins" class="ms-2 text-decoration-none">Quản lý liên
                                kết ngoài</a>
                            </dd>

                            <hr class="text-muted" />

                            <dt class="col-md-4 fs-5 text-dark mt-2">Số điện thoại 2FA:</dt>
                            <dd class="col-md-8 mt-2 mb-4">
                                <p class="text-muted small mb-2">Số điện thoại dùng để nhận tin nhắn SMS xác thực hai yếu tố.</p>
                                <div class="d-flex align-items-center">
                                    <strong class="me-3 fs-5">@(Model.PhoneNumber ?? "Không có")</strong>

                                    @if (Model.PhoneNumber != null)
                                    {
                                        <a asp-controller="Manage" asp-action="AddPhoneNumber"
                                           class="btn btn-outline-secondary btn-sm me-2">Thay đổi</a>
                                        <form asp-controller="Manage" asp-action="RemovePhoneNumber" method="post" role="form"
                                              class="m-0">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Loại bỏ</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-controller="Manage" asp-action="AddPhoneNumber"
                                           class="btn btn-outline-primary btn-sm">Thêm số điện thoại</a>
                                    }
                                </div>
                            </dd>

                            <hr class="text-muted" />

                            <dt class="col-md-4 fs-5 text-dark mt-2">Xác thực 2 yếu tố (2FA):</dt>
                            <dd class="col-md-8 mt-2 mb-4">
                                @if (Model.TwoFactor)
                                {
                                    <form asp-controller="Manage" asp-action="DisableTwoFactorAuthentication" method="post"
                                          class="d-flex align-items-center" role="form">
                                        <span class="badge bg-success fs-6 me-3">Đang kích hoạt</span>
                                        <button type="submit" class="btn btn-danger btn-sm">Hủy / Tắt 2FA</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Manage" asp-action="EnableTwoFactorAuthentication" method="post" role="form">
                                        <span class="badge bg-secondary fs-6 me-3">Đang tắt</span>
                                        <button type="submit" class="btn btn-primary btn-sm">Kích hoạt 2FA</button>
                                    </form>
                                }
                            </dd>

                            <hr class="text-muted" />

                            <dt class="col-md-4 fs-5 text-dark mt-2">Ứng dụng xác thực:</dt>
                            <dd class="col-md-8 mt-2 mb-2">
                                @if (Model.AuthenticatorKey == null)
                                {
                                    <p class="text-muted small">Sử dụng ứng dụng như Google Authenticator hoặc Authy.</p>
                                    <form asp-controller="Manage" asp-action="ResetAuthenticatorKey" method="post" role="form">
                                        <button type="submit" class="btn btn-primary btn-sm">Phát sinh mã Authenticator</button>
                                    </form>
                                }
                                else
                                {
                                    <div class="alert alert-warning p-3">
                                        <p class="mb-1 text-dark">Nhập mã này vào ứng dụng xác thực của bạn:</p>
                                        <h4 class="font-monospace text-danger text-center bg-white p-2 border rounded">
                                            @Model.AuthenticatorKey</h4>
                                        </div>

                                        <form asp-controller="Manage" asp-action="GenerateRecoveryCode" method="post" role="form"
                                              class="mt-3 border-top pt-3">
                                            <p class="text-muted small mb-2">Mã phục hồi sử dụng để đăng nhập khi bạn mất điện thoại.</p>
                                            <button type="submit" class="btn btn-outline-warning text-dark btn-sm">Phát sinh mã phục hồi
                                                mới</button>
                                            </form>
                                        }
                                    </dd>

                                </dl>
                            </div>
                        </div>
                    </div>