@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService authorizationService

@{
    var result = await authorizationService.AuthorizeAsync(this.User, "ViewManageMenu");
}
@if (result.Succeeded)
{
    <ul class="navbar-nav">
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="manageDropdown" role="button" data-bs-toggle="dropdown"
               aria-expanded="false">
                Manage
            </a>

            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="manageDropdown">
                <li>
                    <a class="dropdown-item" asp-area="Database" asp-controller="DbManage" asp-action="Index">
                        Quản lý Database
                    </a>
                </li>

                <li>
                    <hr class="dropdown-divider">
                </li>

                <li>
                    <a class="dropdown-item" asp-area="Contact" asp-controller="Contact" asp-action="Index">
                        Quản lí liên hệ
                    </a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>

                <li>
                    <a class="dropdown-item" asp-area="Blog" asp-controller="Category" asp-action="Index">
                        Quản lý danh mục Blog
                    </a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <a class="dropdown-item" asp-area="Blog" asp-controller="Post" asp-action="Index">
                        Quản lý bài viết Blog
                    </a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>

                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-controller="Role" asp-action="Index">
                        Quản lí vai trò
                    </a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>

                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-controller="User" asp-action="Index">
                        Quản lí thành viên
                    </a>
                </li>
            </ul>
        </li>
    </ul>
}
