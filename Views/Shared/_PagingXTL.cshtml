@* 
    Model:
      - currentPage:int - Trang hiện tại
      - countPages:int - tổng số trang
      - generateUrl:delegate Func<int?, string> trả về URL tương ứng với trang p (1,2,3 ...)
*@

@model App.Models.PagingModel
@{
    int countPages = Math.Max(Model.countpages, 0);

    if (countPages <= 1)
        return;

    int currentPage = Math.Clamp(Model.currentpage, 1, countPages);
    const int visiblePages = 5;
    int startPage = Math.Max(1, currentPage - visiblePages / 2);
    int endPage = Math.Min(countPages, startPage + visiblePages - 1);
    startPage = Math.Max(1, endPage - visiblePages + 1);
    var generateUrl = Model.generateUrl;
}

<nav aria-label="Phân trang">
    <ul class="pagination justify-content-center flex-wrap mb-0">
        @if (currentPage > 1)
        {
            <li class="page-item">
                <a class="page-link" href="@generateUrl(currentPage - 1)" aria-label="Trang trước">
                    Trang trước
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled" aria-disabled="true">
                <span class="page-link">Trang trước</span>
            </li>
        }

        @if (startPage > 1)
        {
            <li class="page-item">
                <a class="page-link" href="@generateUrl(1)">1</a>
            </li>

            @if (startPage > 2)
            {
                <li class="page-item disabled" aria-hidden="true">
                    <span class="page-link">&hellip;</span>
                </li>
            }
        }

        @for (int pageNumber = startPage; pageNumber <= endPage; pageNumber++)
        {
            if (pageNumber == currentPage)
            {
                <li class="page-item active" aria-current="page">
                    <span class="page-link">
                        @pageNumber
                        <span class="visually-hidden">(trang hiện tại)</span>
                    </span>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" href="@generateUrl(pageNumber)">@pageNumber</a>
                </li>
            }
        }

        @if (endPage < countPages)
        {
            @if (endPage < countPages - 1)
            {
                <li class="page-item disabled" aria-hidden="true">
                    <span class="page-link">&hellip;</span>
                </li>
            }

            <li class="page-item">
                <a class="page-link" href="@generateUrl(countPages)">@countPages</a>
            </li>
        }

        @if (currentPage < countPages)
        {
            <li class="page-item">
                <a class="page-link" href="@generateUrl(currentPage + 1)" aria-label="Trang sau">
                    Trang sau
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled" aria-disabled="true">
                <span class="page-link">Trang sau</span>
            </li>
        }
    </ul>
</nav>
